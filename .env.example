# EC2 / Production: all secrets are fetched from AWS SSM Parameter Store by default.
# No .env file is needed on EC2 — just ensure the instance has IAM permissions to read SSM.
#
# SSM parameters used:
#   /fitted/openrouter-api-key
#   /fitted/weather-api-key
#   /fitted/database-url
#   /fitted/jwt-secret-key
#   /fitted/jwt-algorithm         (default: HS256)
#   /fitted/access-token-expire-minutes (default: 1440)
#
# Environment variables (injected by SAM, not SSM):
#   WEATHER_BUCKET_NAME           (set by !Ref WeatherDataBucket in template.yaml)
#
# Local development only — create a .env file with these vars and set USE_SSM=false:

USE_SSM=false
DATABASE_URL=postgresql://fitted_admin:<password>@<rds-endpoint>:5432/fitted
OPENROUTER_API_KEY=<your-key>
WEATHER_API_KEY=<your-key>
JWT_SECRET_KEY=dev-secret-key-change-me-in-prod
WEATHER_BUCKET_NAME=<your-bucket>
